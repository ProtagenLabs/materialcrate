generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  jti        String    @unique
  deviceName String    @default("Unknown device")
  ipAddress  String?
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([jti])
}

model User {
  id            String   @id @default(cuid())
  username      String
  displayName   String
  profilePicture String?
  profileBackground String @default("bg-linear-to-br from-[#E1761F] via-[#ffecdc] to-stone-200")
  theme             String  @default("light")
  visibilityPublicProfile  Boolean @default(true)
  visibilityPublicPosts    Boolean @default(true)
  visibilityPublicComments Boolean @default(true)
  visibilityOnlineStatus   Boolean @default(true)
  emailNotificationsAccountActivity Boolean @default(true)
  emailNotificationsWeeklySummary   Boolean @default(true)
  emailNotificationsProductUpdates  Boolean @default(true)
  emailNotificationsMarketing       Boolean @default(true)
  emailNotificationsUploadReminder  Boolean @default(true)
  lastUploadReminderSentAt          DateTime?
  pushNotificationsLikes    Boolean @default(true)
  pushNotificationsComments Boolean @default(true)
  pushNotificationsFollows  Boolean @default(true)
  pushNotificationsMentions Boolean @default(true)
  email         String
  pendingEmail  String?
  password      String
  linkedSEOs    String[] @default([])
  uninterestedPostIds String[] @default([])
  blockedUserIds String[] @default([])
  subscriptionPlan             String   @default("free")
  subscriptionStartedAt        DateTime @default(now())
  subscriptionEndsAt           DateTime?
  pendingSubscriptionPlan      String?
  pendingSubscriptionAction    String?
  pendingSubscriptionEffectiveAt DateTime?
  gumroadSubscriptionId String? @unique
  gumroadSaleId         String? @unique
  emailVerified Boolean  @default(false)
  emailVerificationToken          String?
  emailVerificationTokenExpiresAt DateTime?
  deleted       Boolean  @default(false)
  deletedAt     DateTime?
  disabled      Boolean  @default(false)
  disabledAt    DateTime?
  disabledUntil DateTime?
  isBot         Boolean  @default(false)
  tokenBalance     Int      @default(0)
  tokensEarned     Int      @default(0)
  tokensRedeemed   Int      @default(0)
  aiTokensUsedDaily    Int       @default(0)
  aiTokensUsedMonthly  Int       @default(0)
  aiTokensDailyResetAt DateTime  @default(now())
  aiTokensMonthlyResetAt DateTime @default(now())
  institution   String?
  institutionVisibility String @default("everyone")
  program       String?
  programVisibility String @default("everyone")
  posts         Post[]   @relation("UserPosts")
  postVersions  PostVersion[] @relation("PostVersionEditor")
  likes         Like[]
  comments      Comment[]
  commentLikes  CommentLike[]
  seoAccounts   SeoAccount[]
  workspace     Workspace?
  archive       Archive?
  hubChats      HubChat[]
  feedInteractions FeedInteraction[]
  followerRelations Follow[] @relation("UserFollowers")
  followingRelations Follow[] @relation("UserFollowing")
  sentFollowRequests FollowRequest[] @relation("FollowRequestRequester")
  receivedFollowRequests FollowRequest[] @relation("FollowRequestTarget")
  mutedUserRelations Mute[] @relation("UserMutedUsers")
  mutedByRelations Mute[] @relation("UserMutedBy")
  notifications Notification[]
  achievements  UserAchievement[]
  reports       Report[]
  tokenTransactions TokenTransaction[]
  cashoutRequests   TokenCashoutRequest[]
  purchases              Purchase[]
  revenueRedirects       RevenueRedirect[]   @relation("RevenueRedirectBeneficiary")
  plagiarismAppeals      PlagiarismAppeal[]  @relation("PlagiarismAppealUser")
  conversationsAsA  Conversation[] @relation("ConversationParticipantA")
  conversationsAsB  Conversation[] @relation("ConversationParticipantB")
  sentChatMessages  ChatMessage[]  @relation("ChatMessageSender")
  sessions               Session[]
  documentRequests       DocumentRequest[]              @relation("UserRequests")
  requestFulfillments    DocumentRequestFulfillment[]   @relation("UserFulfillments")
  fulfillmentLikes       DocumentRequestFulfillmentLike[] @relation("UserFulfillmentLikes")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@index([pendingEmail])
}

model TokenTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   // VIEW_EARN | REDEEM_PRO | REDEEM_PREMIUM | REDEEM_CASH
  amount      Int      // positive = earned, negative = spent
  postId      String?
  description String?
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([postId])
}

model TokenCashoutRequest {
  id            String   @id @default(cuid())
  userId        String
  tokensAmount  Int
  cashAmount    Float
  status        String   @default("pending") // pending | approved | paid | rejected
  payoutMethod  String   // paypal | mobile_money | bank_transfer
  payoutDetails Json     // method-specific fields (email, phone, bank info, etc.)
  adminNote     String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  actorId       String?
  type          String   @default("SYSTEM")
  title         String
  description   String
  icon          String
  profilePicture String?
  achievementId String?
  postId        String?
  commentId     String?
  caseId        String?
  requestId     String?
  unread        Boolean  @default(true)
  time          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, time])
  @@index([userId, unread])
  @@index([userId, type, actorId])
  @@index([postId])
  @@index([caseId])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

enum SeoProvider {
  GOOGLE
  FACEBOOK
}

model SeoAccount {
  id             String      @id @default(cuid())
  userId         String
  provider       SeoProvider
  providerUserId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}

model Post {
  id         String   @id @default(cuid())
  fileUrl    String
  thumbnailUrl String?
  fileType   String   @default("pdf")
  renderedHtmlUrl String?
  pinned     Boolean  @default(false)
  commentsDisabled Boolean @default(false)
  deleted    Boolean  @default(false)
  deletedAt  DateTime?
  title      String
  categories String[]
  description String?
  year       Int?
  viewCount  Int      @default(0)
  isFree     Boolean  @default(true)
  price      Float    @default(0)
  authorId   String?
  author     User?    @relation("UserPosts", fields: [authorId], references: [id], onDelete: SetNull)
  versions   PostVersion[]
  likes      Like[]
  comments   Comment[]
  purchases  Purchase[]
  savedInWorkspaces WorkspaceSavedPost[]
  savedInArchives ArchiveSavedPost[]
  hubChats   HubChat[]
  feedInteractions FeedInteraction[]
  tokenTransactions TokenTransaction[]
  chatAttachments   ChatMessageAttachment[] @relation("PostChatAttachments")
  requestFulfillments DocumentRequestFulfillment[] @relation("PostFulfillments")
  documentFingerprint      DocumentFingerprint?
  contentChunks            ContentChunk[]
  originalPlagiarismCases  PlagiarismCase[] @relation("PlagiarismOriginalPost")
  suspectedPlagiarismCases PlagiarismCase[] @relation("PlagiarismSuspectedPost")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([authorId])
  @@index([categories])
  @@index([deleted, deletedAt])
  @@index([isFree])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  amount    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([postId])
}

model DocumentFingerprint {
  id         String   @id @default(cuid())
  postId     String   @unique
  sha256Hash String
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([sha256Hash])
  @@map("document_fingerprints")
}

model ContentChunk {
  id               String         @id @default(cuid())
  postId           String
  chunkIndex       Int
  chunkType        String
  sha256Hash       String
  minHashSignature Int[]
  text             String         @default("")
  wordCount        Int
  charCount        Int
  createdAt        DateTime       @default(now())

  post     Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  lshBands ChunkLshBand[]

  @@unique([postId, chunkIndex, chunkType])
  @@index([sha256Hash])
  @@index([postId])
  @@map("content_chunks")
}

model ChunkLshBand {
  chunkId   String
  bandIndex Int
  bandHash  BigInt

  chunk ContentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@id([chunkId, bandIndex])
  @@index([bandIndex, bandHash])
  @@map("chunk_lsh_bands")
}

model PostVersion {
  id            String   @id @default(cuid())
  postId        String
  versionNumber Int
  title         String
  categories    String[]
  description   String?
  year          Int?
  fileUrl       String
  thumbnailUrl  String?
  fileType      String   @default("pdf")
  editorId      String?
  createdAt     DateTime @default(now())

  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor User? @relation("PostVersionEditor", fields: [editorId], references: [id], onDelete: SetNull)

  @@unique([postId, versionNumber])
  @@index([postId, createdAt])
  @@index([editorId])
}

model Workspace {
  id        String               @id @default(cuid())
  userId    String               @unique
  name      String               @default("My Workspace")
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders   WorkspaceFolder[]
  savedPosts WorkspaceSavedPost[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model WorkspaceFolder {
  id          String               @id @default(cuid())
  workspaceId String
  name        String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  savedPosts  WorkspaceSavedPost[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model WorkspaceSavedPost {
  id          String           @id @default(cuid())
  workspaceId String
  folderId    String?
  postId      String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder      WorkspaceFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  post        Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([workspaceId, postId])
  @@index([workspaceId, folderId])
  @@index([postId])
}

model Archive {
  id         String            @id @default(cuid())
  userId     String            @unique
  name       String            @default("My Archive")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders    ArchiveFolder[]
  savedPosts ArchiveSavedPost[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model ArchiveFolder {
  id        String             @id @default(cuid())
  archiveId String
  name      String
  archive   Archive            @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  savedPosts ArchiveSavedPost[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([archiveId, name])
  @@index([archiveId])
}

model ArchiveSavedPost {
  id        String         @id @default(cuid())
  archiveId String
  folderId  String?
  postId    String
  archive   Archive        @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  folder    ArchiveFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([archiveId, postId])
  @@index([archiveId, folderId])
  @@index([postId])
}

model HubChat {
  id            String   @id @default(cuid())
  userId        String
  postId        String
  savedPostId   String?
  documentTitle String
  messages      Json     @default("[]")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, postId])
  @@index([userId, updatedAt])
  @@index([postId])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post       Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]     @relation("CommentReplies")
  commentLikes CommentLike[]

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FollowRequest {
  id          String   @id @default(cuid())
  requesterId String
  targetId    String
  status      String   @default("PENDING")
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  requester User @relation("FollowRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FollowRequestTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([requesterId])
  @@index([targetId, status])
  @@index([expiresAt])
}

model Mute {
  muterId  String
  mutedId  String
  createdAt DateTime @default(now())

  muter User @relation("UserMutedUsers", fields: [muterId], references: [id], onDelete: Cascade)
  muted User @relation("UserMutedBy", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([muterId, mutedId])
  @@index([muterId])
  @@index([mutedId])
}

model FeedInteraction {
  id              String   @id @default(cuid())
  userId          String
  postId          String?
  interactionType String
  signalKind      String   @default("positive")
  category        String?
  searchTerm      String?
  durationMs      Int?
  metadata        Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, interactionType, createdAt])
  @@index([userId, signalKind, createdAt])
  @@index([postId, createdAt])
  @@index([category, createdAt])
  @@index([searchTerm, createdAt])
}

model Report {
  id          String   @id @default(cuid())
  userId      String
  category    String
  title       String
  description String
  imageUrls   String[] @default([])
  userAgent   String?
  deviceInfo  String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([resolved])
}

// Ordered so participantAId < participantBId (sorted at write time) to enforce a single row per pair
model Conversation {
  id             String        @id @default(cuid())
  participantAId String
  participantBId String
  participantA   User          @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User          @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([participantAId, participantBId])
  @@index([participantAId, updatedAt])
  @@index([participantBId, updatedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String?      // nullable — message may be attachment-only or unsent
  parentId       String?      // reply-to
  isUnsent       Boolean      @default(false)
  status         String       @default("SENT") // SENT | DELIVERED | READ
  editedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                  @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parent       ChatMessage?          @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies      ChatMessage[]         @relation("MessageReplies")
  attachments  ChatMessageAttachment[]
  edits        ChatMessageEdit[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([conversationId, status, senderId])
  @@index([parentId])
}

model ChatMessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  type      String   // POST | IMAGE | VIDEO | DOCUMENT
  postId    String?
  url       String?
  fileName  String?
  fileSize  String?
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  post    Post?       @relation("PostChatAttachments", fields: [postId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([postId])
}

model ChatMessageEdit {
  id           String   @id @default(cuid())
  messageId    String
  previousText String
  editedAt     DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, editedAt])
}

model PlagiarismCase {
  id                     String    @id @default(cuid())
  originalPostId         String
  suspectedPostId        String
  similarityScore        Float
  verdict                String    // DUPLICATE | SUSPICIOUS | POSSIBLE
  status                 String    @default("PENDING_REVIEW") // PENDING_REVIEW | REVIEWING | RESOLVED | DISMISSED
  matchedChunkCount      Int       @default(0)
  totalChunkCount        Int       @default(0)
  revenueRedirectEnabled Boolean   @default(false)
  matchSummaryJson       Json      @default("{}")
  moderatorId            String?
  moderatorNote          String?
  resolvedAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  originalPost    Post              @relation("PlagiarismOriginalPost", fields: [originalPostId], references: [id], onDelete: Cascade)
  suspectedPost   Post              @relation("PlagiarismSuspectedPost", fields: [suspectedPostId], references: [id], onDelete: Cascade)
  revenueRedirect RevenueRedirect?
  appeals         PlagiarismAppeal[]
  events          CaseEvent[]

  @@unique([originalPostId, suspectedPostId])
  @@index([originalPostId])
  @@index([suspectedPostId])
  @@index([status])
}

model RevenueRedirect {
  id                 String   @id @default(cuid())
  caseId             String   @unique
  sourcePostId       String
  beneficiaryPostId  String
  beneficiaryUserId  String
  redirectPercentage Float    @default(100)
  reason             String
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  case            PlagiarismCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  beneficiaryUser User           @relation("RevenueRedirectBeneficiary", fields: [beneficiaryUserId], references: [id], onDelete: Cascade)

  @@index([sourcePostId, active])
}

model PlagiarismAppeal {
  id        String   @id @default(cuid())
  caseId    String
  userId    String
  reason    String
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  response  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case PlagiarismCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User           @relation("PlagiarismAppealUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([userId])
}

model CaseEvent {
  id          String   @id @default(cuid())
  caseId      String
  type        String
  description String
  actorId     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  case PlagiarismCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
}

model DocumentRequest {
  id                    String    @id @default(cuid())
  authorId              String
  title                 String
  description           String
  categories            String[]
  bounty                Int?
  bountyEscrowedAt      DateTime?
  acceptedFulfillmentId String?   @unique
  bountyReleasedAt      DateTime?
  solved                Boolean   @default(false)
  closed                Boolean   @default(false)
  deleted               Boolean   @default(false)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  author              User                         @relation("UserRequests", fields: [authorId], references: [id], onDelete: Cascade)
  fulfillments        DocumentRequestFulfillment[] @relation("RequestFulfillments")
  acceptedFulfillment DocumentRequestFulfillment?  @relation("AcceptedFulfillment", fields: [acceptedFulfillmentId], references: [id])

  @@index([authorId, createdAt])
  @@index([solved, closed, deleted, createdAt])
  @@index([bountyEscrowedAt])
}

model DocumentRequestFulfillment {
  id        String   @id @default(cuid())
  requestId String
  postId    String
  authorId  String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request     DocumentRequest                  @relation("RequestFulfillments", fields: [requestId], references: [id], onDelete: Cascade)
  post        Post                             @relation("PostFulfillments", fields: [postId], references: [id], onDelete: Cascade)
  author      User                             @relation("UserFulfillments", fields: [authorId], references: [id], onDelete: Cascade)
  acceptedFor DocumentRequest?                 @relation("AcceptedFulfillment")
  likes       DocumentRequestFulfillmentLike[]

  @@unique([requestId, postId])
  @@index([requestId, likeCount])
  @@index([requestId, createdAt])
  @@index([authorId])
  @@index([postId])
}

model DocumentRequestFulfillmentLike {
  userId        String
  fulfillmentId String
  createdAt     DateTime @default(now())

  user        User                       @relation("UserFulfillmentLikes", fields: [userId], references: [id], onDelete: Cascade)
  fulfillment DocumentRequestFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)

  @@id([userId, fulfillmentId])
  @@index([fulfillmentId])
}
